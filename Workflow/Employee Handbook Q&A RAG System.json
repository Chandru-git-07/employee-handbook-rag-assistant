      "name": "Extract Handbook Text"
    },
    {
      "parameters": {
        "jsCode": "const rawText = $input.first().json.text;\n\nif (!rawText || typeof rawText !== 'string') {\n  throw new Error('No extracted text found in json.text');\n}\n\n// basic cleanup\nconst text = rawText\n  .replace(/\\r/g, '')\n  .replace(/\\n{2,}/g, '\\n')\n  .trim();\n\nconst chunkSize = 1200;   // characters per chunk\nconst overlap = 200;      // overlap between chunks\n\nconst chunks = [];\nlet start = 0;\nlet chunkIndex = 1;\n\nwhile (start < text.length) {\n  const end = Math.min(start + chunkSize, text.length);\n  const chunkText = text.slice(start, end).trim();\n\n  if (chunkText) {\n    chunks.push({\n      json: {\n        chunk_id: `employee_handbook_chunk_${chunkIndex}`,\n        document_name: 'employee_handbook.pdf',\n        source: 'employee_handbook',\n        text: chunkText\n      }\n    });\n    chunkIndex++;\n  }\n\n  if (end === text.length) break;\n  start += chunkSize - overlap;\n}\n\nreturn chunks;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        672,
        0
      ],
      "id": "1c2a39ee-b8b0-49cc-9b9d-f5e3e9439067",
      "name": "Split Handbook into Chunks"
    },
    {
      "parameters": {
        "jsCode": "return items.map(item => {\n  return {\n    json: {\n      pageContent: item.json.text,\n      metadata: {\n        chunk_id: item.json.chunk_id,\n        document_name: item.json.document_name,\n        source: item.json.source\n      }\n    }\n  };\n});"
      },
